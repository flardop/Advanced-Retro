{
  "name": "advanced-retro",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3020",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean:temp": "bash scripts/clean-temp.sh",
    "clean:temp:dry": "bash scripts/clean-temp.sh --dry-run",
    "images:setup": "bash scripts/setup-image-tools.sh",
    "images:organize": "npx tsx scripts/organize-local-images.ts --apply --mode=copy",
    "images:mapping:template": "npx tsx scripts/generate-image-mapping-template.ts",
    "images:cluster": ". .venv-imaging/bin/activate && python scripts/cluster-pending-images.py",
    "images:cluster:apply": "npx tsx scripts/apply-cluster-mapping.ts",
    "images:catalog:export": "npx tsx scripts/export-products-catalog.ts",
    "images:seed:pending-products": "npx tsx scripts/seed-missing-products-from-pending.ts",
    "images:mapping:autofill": "npx tsx scripts/autofill-mapping-known-files.ts",
    "images:mapping:dedupe": "npx tsx scripts/mark-duplicate-variants.ts",
    "images:mapping:apply": "npx tsx scripts/apply-image-mapping.ts --apply",
    "images:repair:splash": "npx tsx scripts/repair-splash-images.ts",
    "images:upload": "npx tsx scripts/upload-organized-images-to-supabase.ts --apply",
    "images:pipeline": "bash scripts/run-image-pipeline.sh",
    "images:fill:fallbacks": "npx tsx scripts/fill-fallback-product-images.ts --limit=220",
    "images:community:normalize": "npx tsx scripts/normalize-community-listing-images.ts --apply",
    "products:dedupe": "npx tsx scripts/deduplicate-products.ts",
    "catalog:expand": "npx tsx scripts/expand-catalog-internet.ts",
    "catalog:ensure-components": "npx tsx scripts/ensure-complete-game-components.ts",
    "catalog:enrich-copy": "npx tsx scripts/enrich-product-copy.ts",
    "wallet:set-balance": "npx tsx scripts/set-user-wallet-balance.ts",
    "seed:demo:engagement": "DEMO_SEED_I_UNDERSTAND=YES npx tsx scripts/seed-demo-engagement.ts",
    "simulate:demo:traffic": "DEMO_ACTIVITY_I_UNDERSTAND=YES npx tsx scripts/simulate-user-activity.ts --minutes=5",
    "seo:audit": "npx tsx scripts/seo-audit-report.ts",
    "smoke:audit": "npx tsx scripts/smoke-audit.ts",
    "make:video-worker": "node automation/make-gaming-news/video-worker/worker-server.mjs",
    "make:video:render-example": "node automation/make-gaming-news/video-worker/render-news-video.mjs --payload automation/make-gaming-news/video-worker/payload.example.json --output-dir automation/make-gaming-news/video-worker/output --job-id DEMO-LOCAL"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@supabase/auth-helpers-nextjs": "^0.9.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.45.4",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@vercel/analytics": "^1.6.1",
    "date-fns": "^4.1.0",
    "gsap": "^3.15.0",
    "leva": "^0.9.36",
    "lucide-react": "^1.14.0",
    "next": "^14.2.35",
    "nodemailer": "^8.0.6",
    "postprocessing": "^6.39.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "stripe": "^16.8.0",
    "three": "^0.179.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tailwindcss/line-clamp": "^0.4.4",
    "@types/node": "^20.14.11",
    "@types/nodemailer": "^6.4.22",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "qs": "^6.15.0"
  }
}
